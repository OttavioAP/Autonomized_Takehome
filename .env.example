# Postgres (consumed by the postgres container itself)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=team_activity_monitor

# FastAPI
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/team_activity_monitor
OPENROUTER_API_KEY=<key>

# JIRA (demo/sandbox site)
JIRA_BASE_URL=https://<your-site>.atlassian.net
JIRA_EMAIL=<email used to log into the JIRA site>
JIRA_API_TOKEN=<key>

# GitHub (demo/sandbox repo)
GITHUB_TOKEN=<fine-grained PAT, read-only, scoped to the demo repo>
GITHUB_REPO=<owner>/<demo-repo-name>
