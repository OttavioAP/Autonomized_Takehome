# Postgres (consumed by the postgres container itself)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=team_activity_monitor

# FastAPI
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/team_activity_monitor
OPENROUTER_API_KEY=<key>

# Azure AD SSO (confidential client / OIDC). App registration needs a matching
# web redirect URI (http://localhost:8000/auth/callback for local dev).
AZURE_TENANT_ID=<tenant id>
AZURE_CLIENT_ID=<app registration's application (client) id>
AZURE_CLIENT_SECRET=<app registration client secret>
AZURE_REDIRECT_URI=http://localhost:8000/auth/callback

# JIRA OAuth 2.0 (3LO) app - per-user OAuth, not the old Basic-auth service
# account (see blueprints/plans/features/oauth-integration.md).
JIRA_OAUTH_CLIENT_ID=<Atlassian developer console app's client id>
JIRA_OAUTH_CLIENT_SECRET=<client secret>
JIRA_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/jira/callback

# GitHub OAuth App (classic, not a "GitHub App") - per-user OAuth. GitHub only allows
# one callback URL per app, so local dev and prod need two SEPARATE app registrations
# (unlike JIRA, which supports multiple redirect URIs on one app). Put the LOCAL app's
# credentials here; the prod app's go to deploy.yml's GitHub Actions secrets instead
# (GITHUB_OAUTH_CLIENT_ID_PROD / GITHUB_OAUTH_CLIENT_SECRET_PROD) and get injected under
# these same var names only at deploy time - same pattern as AZURE_REDIRECT_URI_PROD.
GITHUB_OAUTH_CLIENT_ID=<local-callback GitHub OAuth App's client id>
GITHUB_OAUTH_CLIENT_SECRET=<client secret>
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/github/callback

# Azure Key Vault (session/user OAuth token storage - the one narrow MVP
# exception to this project's otherwise env-var-only config posture).
KEY_VAULT_URI=https://<vault-name>.vault.azure.net/
